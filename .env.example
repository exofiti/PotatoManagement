DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_COMMAND_CHANNEL_ID=
# 선택 사항: 밴 감사 로그 채널. 비우면 콘솔에 기록합니다.
DISCORD_LOG_CHANNEL_ID=
# 쉼표로 구분합니다. Discord 관리자는 별도 등록 없이 허용됩니다.
DISCORD_ALLOWED_ROLE_IDS=
# 선택 사항: 기본값은 프로젝트의 donations.db입니다.
DONATIONS_DB_PATH=

# ── 처벌 관리 ──────────────────────────────────────────────
# 현재 시즌 식별자. /처분 으로 기록되는 데이터와 기본 조회 시즌에 사용됩니다.
CURRENT_SEASON=S1
# 선택 사항: /처벌가져오기 의 기본 대상이 되는 처벌 로그 채널 ID.
DISCORD_PUNISHMENT_LOG_CHANNEL_ID=

# ── 처벌 콘솔 명령 템플릿 (플러그인에 맞게 수정) ───────────
# 사용 가능한 치환자: {name} {days} {reason}
# 기본값은 LiteBans 계열 기준입니다.
PUNISH_COMMAND_WARN=warn {name} {reason}
PUNISH_COMMAND_TEMPBAN=tempban {name} {days}d {reason}
PUNISH_COMMAND_BAN=ban {name} {reason}

# ── PotatoVerify 연동 계정 데이터 ──────────────────────────
# 디스코드ID <-> 마크 UUID/닉네임 조회에 사용합니다.
# json 또는 sqlite 로 토글합니다. 비우거나 none 이면 /연동등록 수동 매핑만 사용합니다.
VERIFY_SOURCE_TYPE=none

# 필드명(컬럼/키)을 서버 환경에 맞게 조정할 수 있습니다.
VERIFY_FIELD_DISCORD=discordId
VERIFY_FIELD_UUID=uuid
VERIFY_FIELD_NAME=name

# VERIFY_SOURCE_TYPE=json 일 때
# user-data.json 경로. 형식: { "users": [ { discordId, uuid, name } ] } 또는 배열/객체 맵.
VERIFY_JSON_PATH=
# 선택 사항: 배열이 담긴 최상위 키. 기본값은 users 입니다.
VERIFY_JSON_ROOT=users

# VERIFY_SOURCE_TYPE=sqlite 일 때
# Verify SQLite 파일 경로 (읽기 전용으로 엽니다).
VERIFY_SQLITE_PATH=
# 선택 사항: 기본값은 users 입니다.
VERIFY_SQLITE_TABLE=users
